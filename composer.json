{
    "name": "commuterlink/backend-lost-found",
    "description": "Backend REST API for CommuterLink Nusantara Lost & Found System",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-fileinfo": "*",
        "lcobucci/jwt": "^4.1.5 || ^5.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}